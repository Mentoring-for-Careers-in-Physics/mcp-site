---
import CompanyCard from "../components/CompanyCard.astro";
import Hero from "../components/Hero.astro";
import MentorCard from "../components/MentorCard.astro";
import NewsCard from "../components/NewsCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import companies from "../data/companies.json";
import mentors from "../data/mentors.json";
import newsItems from "../data/news.json";
import site from "../data/site.json";
import videos from "../data/videos.json";
import {
  BASE,
  SUPPORTERS_BANNER,
  assetPath,
  buildCompanies,
  buildExternalLinks,
  buildMentors,
  buildNewsFeed,
  buildVideos,
  monogram,
} from "../utils/content.js";

const links = buildExternalLinks(site);
const mentorDirectory = buildMentors(mentors, companies);
const companyDirectory = buildCompanies(companies, mentors);
const newsFeed = buildNewsFeed(newsItems);
const videoFeed = buildVideos(videos);
const spotlightOptions = mentorDirectory.filter((mentor) => mentor.hasPhoto);
const spotlight = spotlightOptions[0] || mentorDirectory[0];
const spotlightData = spotlightOptions.map((mentor) => ({
  name: mentor.name,
  title: mentor.title,
  organizationLabel: mentor.organizationLabel,
  organizations: mentor.organizations,
  excerpt: mentor.excerpt,
  image: mentor.image,
}));
const spotlightJson = JSON.stringify(spotlightData).replace(/</g, "\\u003c");
const mentorHighlights = spotlightOptions.slice(0, 3);
const companyHighlights = companyDirectory
  .filter((company) => company.website)
  .slice(0, 6);
const featuredVideo = videoFeed[0];
const supporters = (site.supporters || []).map((supporter) => ({
  ...supporter,
  image: assetPath(supporter.image),
}));
const featuredSupporter = supporters[0];
---

<BaseLayout
  title="MCP | Mentoring for Careers in Physics"
  description="Mentoring for Careers in Physics connects William & Mary students with accomplished mentors across research, industry, government, and alumni leadership."
  active="home"
  site={site}
>
  <Hero
    title={"See your future in<br><em>physics &amp; engineering.</em>"}
    summary="MCP connects undergraduate students with accomplished mentors across research, industry, government, and alumni leadership."
    actions={[
      { label: "Meet all mentors", href: `${BASE}mentors/` },
      {
        label: "Join the program",
        href: links.mentee,
        variant: "secondary",
        external: true,
      },
    ]}
    stats={[
      { value: mentorDirectory.length, label: "Mentors" },
      { value: companyDirectory.length, label: "Organizations" },
      { value: "2021", label: "Established" },
    ]}
  >
    <div class="spotlight-card" slot="media" data-mentor-spotlight>
      <div class="spotlight-card__media">
        <img
          src={spotlight.image}
          alt={`Portrait of ${spotlight.name}`}
          loading="eager"
          fetchpriority="high"
          data-mentor-spotlight-image
        />
      </div>
      <div class="spotlight-card__body">
        <span class="kicker">Mentor Spotlight</span>
        <div class="spotlight-card__title" data-mentor-spotlight-name>
          {spotlight.name}
        </div>
        <p class="spotlight-card__role" data-mentor-spotlight-role>
          {spotlight.title} · {spotlight.organizationLabel}
        </p>
        <div class="organization-pill-row" data-mentor-spotlight-organizations>
          {
            spotlight.organizations.map((organization) => (
              <span class="organization-pill">{organization}</span>
            ))
          }
        </div>
        <p class="spotlight-card__summary" data-mentor-spotlight-summary>
          {spotlight.excerpt}
        </p>
        <a class="text-link" href={`${BASE}mentors/`}
          >Explore the mentor directory</a
        >
      </div>
    </div>
  </Hero>

  <script
    id="mentor-spotlight-data"
    type="application/json"
    set:html={spotlightJson}
  />
  <script>
    const dataElement = document.getElementById("mentor-spotlight-data");
    const spotlightCard = document.querySelector("[data-mentor-spotlight]");

    function rememberSpotlight(name) {
      try {
        window.localStorage.setItem("mcp:mentor-spotlight", name);
      } catch {
        // Storage may be unavailable in private browsing or locked-down browsers.
      }
    }

    function lastSpotlightName() {
      try {
        return window.localStorage.getItem("mcp:mentor-spotlight");
      } catch {
        return "";
      }
    }

    if (dataElement && spotlightCard) {
      const mentors = JSON.parse(dataElement.textContent || "[]");
      const lastName = lastSpotlightName();
      const eligibleMentors =
        mentors.length > 1
          ? mentors.filter((mentor) => mentor.name !== lastName)
          : mentors;
      const selected =
        eligibleMentors[Math.floor(Math.random() * eligibleMentors.length)];

      if (selected) {
        const image = spotlightCard.querySelector(
          "[data-mentor-spotlight-image]",
        );
        const name = spotlightCard.querySelector(
          "[data-mentor-spotlight-name]",
        );
        const role = spotlightCard.querySelector(
          "[data-mentor-spotlight-role]",
        );
        const organizations = spotlightCard.querySelector(
          "[data-mentor-spotlight-organizations]",
        );
        const summary = spotlightCard.querySelector(
          "[data-mentor-spotlight-summary]",
        );

        if (image instanceof HTMLImageElement) {
          image.src = selected.image;
          image.alt = `Portrait of ${selected.name}`;
        }
        if (name) name.textContent = selected.name;
        if (role) {
          role.textContent = selected.organizationLabel
            ? `${selected.title} · ${selected.organizationLabel}`
            : selected.title;
        }
        if (organizations) {
          organizations.replaceChildren(
            ...selected.organizations.map((organization) => {
              const pill = document.createElement("span");
              pill.className = "organization-pill";
              pill.textContent = organization;
              return pill;
            }),
          );
        }
        if (summary) summary.textContent = selected.excerpt;
        rememberSpotlight(selected.name);
      }
    }
  </script>

  <section class="section section--white section--bordered">
    <div class="shell">
      <div class="video-feature">
        <div class="video-copy">
          <span class="kicker">MCP Video</span>
          <h2>Watch MCP in motion.</h2>
          <p>{featuredVideo.description}</p>
          <div class="section-actions">
            <a
              class="btn btn-primary btn-sm"
              href={featuredVideo.watchUrl}
              target="_blank"
              rel="noopener">Watch on {featuredVideo.provider}</a
            >
            <a class="text-link" href={`${BASE}videos/`}>See all videos</a>
          </div>
        </div>
        <div class="video-frame" aria-label={featuredVideo.title}>
          <iframe
            src={featuredVideo.embedUrl}
            title={featuredVideo.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Current News</span>
          <h2>The latest from MCP.</h2>
        </div>
        <a class="btn btn-secondary btn-sm" href={`${BASE}news/`}
          >See all news</a
        >
      </div>
      <div class="news-grid">
        {newsFeed.slice(0, 3).map((article) => <NewsCard article={article} />)}
      </div>
    </div>
  </section>

  <section id="friends" class="section section--white section--bordered">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Supported By</span>
          <h2>Friends helping MCP grow.</h2>
        </div>
      </div>

      <div class="support-story-card">
        <div class="support-story-card__media">
          <img
            src={featuredSupporter?.image || SUPPORTERS_BANNER}
            alt={featuredSupporter
              ? `${featuredSupporter.name} banner`
              : "MCP supporters"}
            loading="lazy"
          />
        </div>
        <div class="support-story-card__body">
          <span class="kicker">Featured Supporter</span>
          <h3>{featuredSupporter?.name || "MCP Friends and Supporters"}</h3>
          <p class="section-copy">
            {featuredSupporter?.description || site.story}
          </p>
          <div class="section-actions" style="margin-top:1.25rem">
            {
              featuredSupporter?.website && (
                <a
                  class="btn btn-secondary btn-sm"
                  href={featuredSupporter.website}
                  target="_blank"
                  rel="noopener"
                >
                  Learn more
                </a>
              )
            }
            <a class="text-link" href={`${BASE}give/`}>Support MCP</a>
          </div>
        </div>
      </div>

      <div class="supporter-grid">
        {
          supporters.map((supporter) => (
            <a
              class="supporter-card"
              href={supporter.website}
              target="_blank"
              rel="noopener"
            >
              <div
                class="supporter-card__media"
                style={
                  supporter.mediaBackground
                    ? `background:${supporter.mediaBackground}`
                    : undefined
                }
              >
                {supporter.image ? (
                  <img
                    src={supporter.image}
                    alt={`${supporter.name} logo`}
                    loading="lazy"
                  />
                ) : (
                  <span class="supporter-card__monogram">
                    {monogram(supporter.name)}
                  </span>
                )}
              </div>
              <div class="supporter-card__body">
                <span class="kicker">{supporter.subtitle}</span>
                <h3>{supporter.name}</h3>
                <p class="section-copy">{supporter.description}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">How MCP Works</span>
          <h2>What students gain.</h2>
        </div>
        <a
          class="btn btn-primary btn-sm"
          href={links.mentee}
          target="_blank"
          rel="noopener">Join MCP</a
        >
      </div>

      <div class="works-grid">
        <article class="works-card works-card--accent">
          <div class="works-num">01</div>
          <div>
            <h3>1:1 Matching</h3>
            <p>
              Conversations stay practical, personal, and career-facing, matched
              to what each student is weighing.
            </p>
          </div>
        </article>
        <article class="works-card">
          <div class="works-num">02</div>
          <div>
            <h3>Career Fluency</h3>
            <p>
              Students hear how physics translates into real roles, from
              national labs to startups to public service.
            </p>
          </div>
        </article>
        <article class="works-card">
          <div class="works-num">03</div>
          <div>
            <h3>Belonging</h3>
            <p>
              Seeing women and gender minorities thriving in STEM changes what
              feels possible. That shift is the point.
            </p>
          </div>
        </article>
      </div>

      <div class="works-dark-panel">
        <div class="works-dark-header">
          <div>
            <span class="kicker kicker-light">Shared Value</span>
            <h2>What mentors and organizations gain.</h2>
          </div>
          <div class="section-actions">
            <a class="btn btn-outline-light btn-sm" href={links.mentor}
              >Become a mentor</a
            >
            <a class="btn btn-outline-light btn-sm" href={links.director}
              >Contact director</a
            >
          </div>
        </div>
        <div class="works-dark-grid">
          <article class="works-dark-card">
            <div class="works-dark-num">01</div>
            <h3>Stronger Talent Pipelines</h3>
            <p>
              Organizations build earlier relationships with thoughtful physics
              students exploring research, engineering, data, and technical
              careers.
            </p>
          </article>
          <article class="works-dark-card">
            <div class="works-dark-num">02</div>
            <h3>Meaningful Community Impact</h3>
            <p>
              Mentors invest in the next generation while staying connected to a
              mission grounded in access, visibility, and belonging.
            </p>
          </article>
          <article class="works-dark-card">
            <div class="works-dark-num">03</div>
            <h3>Closer W&amp;M Connections</h3>
            <p>
              Participating entities deepen ties with William & Mary through
              alumni engagement, student conversations, and future
              collaboration.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Meet the Mentors</span>
          <h2>Meet the women widening what a physics future can look like.</h2>
        </div>
        <div class="section-actions">
          <a class="text-link" href={`${BASE}mentors/`}
            >Browse the full directory</a
          >
          <a class="btn btn-secondary btn-sm" href={links.mentor}
            >Become a mentor</a
          >
        </div>
      </div>
      <div class="profile-grid">
        {mentorHighlights.map((mentor) => <MentorCard mentor={mentor} />)}
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Where Mentors Work</span>
          <h2>Across industry, research, and government.</h2>
        </div>
        <a class="text-link" href={`${BASE}industry/`}
          >See all partner organizations</a
        >
      </div>
      <div class="company-grid">
        {companyHighlights.map((company) => <CompanyCard company={company} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="cta-panel">
        <div>
          <span class="kicker kicker-light">Support MCP</span>
          <h2>Help us grow what's possible.</h2>
          <p style="max-width:54ch">
            MCP thrives because mentors, students, alumni, faculty, and friends
            choose to invest in what's next. Support helps sustain mentoring
            matches, events, student opportunities, and the long-term future of
            the program.
          </p>
          <div class="cta-actions">
            <a
              class="btn"
              href={links.mentee}
              target="_blank"
              rel="noopener"
              style="background:white;color:var(--wine);font-weight:700"
              >Join as a student</a
            >
            <a class="btn btn-outline-light" href={links.mentor}
              >Become a mentor</a
            >
            <a class="btn btn-outline-light" href={`${BASE}give/`}
              >Give to MCP</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
