---
import TeamCard from "../components/TeamCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import events from "../data/events.json";
import retiredTeam from "../data/retired-team.json";
import site from "../data/site.json";
import team from "../data/team.json";
import {
  SUPPORTERS_BANNER,
  buildTeamDirectory,
  normalizeEventArchive,
} from "../utils/content.js";

const directory = buildTeamDirectory(team, retiredTeam);
const eventArchive = normalizeEventArchive(events);
---

<BaseLayout
  title="Leadership"
  description="Meet the leadership, advisors, and student team behind Mentoring for Careers in Physics."
  active="team"
  site={site}
>
  <section class="page-hero">
    <div class="shell">
      <div class="page-hero-grid">
        <div>
          <span class="kicker">Leadership &amp; Team</span>
          <h1>The people caring for MCP.</h1>
          <p>
            This page reflects the full current team, advisor listing, and
            retired-team archive from the shared MCP data files.
          </p>
        </div>
        <div class="hero-stat-card">
          <span class="kicker">Team</span>
          <div class="metric">
            <strong>{directory.current.length}</strong><span
              >Current team members</span
            >
          </div>
          <div class="metric">
            <strong>{directory.advisors.length}</strong><span
              >Faculty advisors</span
            >
          </div>
          <div class="metric">
            <strong>{directory.archive.length}</strong><span
              >Archive members</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Current Team</span>
          <h2>Running the program now.</h2>
        </div>
        <a class="text-link" href="/contact/">Contact leadership</a>
      </div>
      <div class="profile-grid">
        {
          directory.current.map((person) => (
            <TeamCard person={person} label="Leadership" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Founders &amp; Advisors</span>
          <h2>The founding perspective.</h2>
        </div>
      </div>
      <div class="profile-grid">
        {
          directory.advisors.map((person) => (
            <TeamCard person={person} label="Advisor" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Program Archive</span>
          <h2>Previous student leaders.</h2>
        </div>
      </div>
      <div class="profile-grid-4">
        {
          directory.archive.map((person) => (
            <TeamCard person={person} label="Program Archive" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Event Materials</span>
          <h2>Shared program archive.</h2>
        </div>
      </div>
      <div class="company-grid">
        {
          eventArchive.flatMap((event) =>
            event.assets.map((asset) => (
              <a
                class="event-card"
                href={asset.image}
                target="_blank"
                rel="noopener"
              >
                <span class="company-sector">Event Archive</span>
                <h3>{asset.label}</h3>
                <p>{event.title}</p>
                <img src={asset.image} alt={asset.label} loading="lazy" />
                <span class="text-link">Open material</span>
              </a>
            )),
          )
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="support-story-card">
        <div class="support-story-card__body">
          <span class="kicker">Society of 1918</span>
          <h2>MCP Friends &amp; Supporters.</h2>
          <p class="section-copy">{site.story}</p>
        </div>
        <div class="support-story-card__media">
          <img
            src={SUPPORTERS_BANNER}
            alt="Society of 1918 banner"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
