---
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import { BASE, buildExternalLinks, socialPlatform } from "../utils/content.js";

const links = buildExternalLinks(site);
const mailtoAction = `mailto:${links.email}?subject=MCP%20Website%20Inquiry`;
const ways = [
  {
    title: "Join as a student",
    kicker: "Mentees",
    desc: "W&M physics students can apply to be matched with a mentor for guided career conversations.",
    action: "Apply now",
    href: links.mentee,
    external: true,
  },
  {
    title: "Become a mentor",
    kicker: "Mentors",
    desc: "Accomplished women in physics and engineering can join the network and guide the next generation.",
    action: "Volunteer",
    href: links.mentor,
  },
  {
    title: "Give to MCP",
    kicker: "Donors",
    desc: "Support program events, operational costs, and the expansion of mentoring access to more students.",
    action: "Donate",
    href: `${BASE}give/`,
  },
];
---

<BaseLayout
  title="Contact"
  description="Contact Mentoring for Careers in Physics at William & Mary."
  active="contact"
  site={site}
>
  <section class="page-hero">
    <div class="shell">
      <span class="kicker">Get in Touch</span>
      <h1>Let's connect.</h1>
      <p>{site.summary}</p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Ways to Engage</span>
          <h2>How would you like to be involved?</h2>
        </div>
      </div>
      <div class="engagement-grid">
        {
          ways.map((way, index) => (
            <article
              class="info-panel"
              style={
                index === 2 ? "background:var(--wine);color:white" : undefined
              }
            >
              <span class:list={["kicker", index === 2 && "kicker-light"]}>
                {way.kicker}
              </span>
              <h3 style={index === 2 ? "color:white" : undefined}>
                {way.title}
              </h3>
              <p
                style={index === 2 ? "color:rgba(255,255,255,0.72)" : undefined}
              >
                {way.desc}
              </p>
              <a
                class="text-link"
                href={way.href}
                target={way.external ? "_blank" : undefined}
                rel={way.external ? "noopener" : undefined}
                style={index === 2 ? "color:white" : undefined}
              >
                {way.action}
              </a>
            </article>
          ))
        }
      </div>

      <div class="contact-grid" style="margin-top:4rem">
        <form
          class="contact-form info-panel"
          action={mailtoAction}
          method="post"
          enctype="text/plain"
        >
          <div>
            <span class="kicker">Email MCP</span>
            <h2>Send a message.</h2>
            <p class="section-copy" style="margin-top:0.8rem">
              This static site opens an email draft instead of pretending to
              submit a form. No message is stored on the website.
            </p>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-name">Your name</label>
            <input
              class="form-input"
              id="contact-name"
              name="name"
              placeholder="Full name"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-email">Email address</label>
            <input
              class="form-input"
              id="contact-email"
              type="email"
              name="email"
              placeholder="your@email.com"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-role">I am a...</label>
            <select class="form-select" id="contact-role" name="role">
              <option value="student">W&M Physics student</option>
              <option value="mentor">Potential mentor</option>
              <option value="donor">Donor / supporter</option>
              <option value="faculty">Faculty / collaborator</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-message">Message</label>
            <textarea
              class="form-textarea"
              id="contact-message"
              name="message"
              placeholder="Tell us how we can help, or what you would like to know about MCP."
              required></textarea>
          </div>
          <button class="btn btn-primary" type="submit">Open email draft</button
          >
        </form>

        <div style="display:flex;flex-direction:column;gap:1.1rem">
          <div class="contact-info">
            <div>
              <div class="contact-item-label">Email</div>
              <a class="contact-item-value" href={`mailto:${links.email}`}
                >{links.email}</a
              >
            </div>
            <div>
              <div class="contact-item-label">Program</div>
              <div class="contact-item-value">
                Mentoring for Careers in Physics
              </div>
              <p class="section-copy">William &amp; Mary Physics Department</p>
            </div>
            <div>
              <div class="contact-item-label">Location</div>
              <div class="contact-item-value">Williamsburg, Virginia</div>
            </div>
            <div>
              <div class="contact-item-label">Social</div>
              <div class="social-list" style="margin-top:0.5rem">
                {
                  links.socialLinks.map((url) => (
                    <a
                      class="social-chip"
                      href={url}
                      target="_blank"
                      rel="noopener"
                    >
                      {socialPlatform(url)}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="give-cta-panel" style="margin-top:0">
            <span class="kicker kicker-light">Ready to give to MCP?</span>
            <h3>Support the program.</h3>
            <p style="margin-top:0.75rem">
              Your support helps fund events, program operations, and expanded
              mentorship access.
            </p>
            <a
              class="btn btn-full"
              href={`${BASE}give/`}
              style="margin-top:1.25rem;background:white;color:var(--wine);font-weight:700"
              >Give to MCP</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
