---
import { BASE, NAV_LINKS, buildExternalLinks } from "../utils/content.js";

const { site = {}, active = "home" } = Astro.props;
const links = buildExternalLinks(site);
---

<header class="site-header" data-site-header>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <nav class="nav" aria-label="Primary navigation">
    <div class="nav-inner">
      <a class="brand" href={BASE} aria-label="MCP home">
        <span class="brand-mark">MCP</span>
        <span class="brand-text">
          <strong>Mentoring for Careers in Physics</strong>
          <small>William &amp; Mary</small>
        </span>
      </a>

      <div class="nav-links">
        {
          NAV_LINKS.map((link) => (
            <a
              class:list={["nav-link", active === link.key && "is-active"]}
              href={link.href}
              aria-current={active === link.key ? "page" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="nav-actions">
        <a class="nav-join" href={links.mentee} target="_blank" rel="noopener"
          >Join us</a
        >
        <a class="nav-give" href={`${BASE}give/`}>Give</a>
        <button
          class="nav-hamburger"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Open menu"
          data-nav-toggle
        >
          <svg
            width="18"
            height="14"
            viewBox="0 0 18 14"
            fill="none"
            aria-hidden="true"
          >
            <rect width="18" height="2" rx="1" fill="currentColor"></rect>
            <rect y="6" width="18" height="2" rx="1" fill="currentColor"></rect>
            <rect y="12" width="18" height="2" rx="1" fill="currentColor"
            ></rect>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div class="nav-mobile" id="site-nav" data-mobile-menu hidden>
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          aria-current={active === link.key ? "page" : undefined}
        >
          {link.label}
        </a>
      ))
    }
    <div class="nav-mobile-actions">
      <a
        class="btn btn-ghost btn-sm"
        href={links.mentee}
        target="_blank"
        rel="noopener">Join us</a
      >
      <a class="btn btn-primary btn-sm" href={`${BASE}give/`}>Give</a>
    </div>
  </div>
</header>
