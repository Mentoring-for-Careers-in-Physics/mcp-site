---
const { video } = Astro.props;
---

<article class="video-card">
  <div class="video-card__media">
    <iframe
      src={video.embedUrl}
      title={video.title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen></iframe>
  </div>
  <div class="video-card__body">
    <span class="news-card__eyebrow">{video.dateLabel} · {video.provider}</span>
    <h3 class="news-card__title">{video.title}</h3>
    <p class="video-card__summary">{video.description}</p>
    <div class="chip-row">
      <span class="chip chip--soft">{video.category}</span>
    </div>
    <div class="section-actions" style="margin-top:1rem">
      <a
        class="btn btn-primary btn-sm"
        href={video.watchUrl}
        target="_blank"
        rel="noopener">Watch on {video.provider}</a
      >
      {
        video.relatedHref && (
          <a class="text-link" href={video.relatedHref}>
            Related news
          </a>
        )
      }
    </div>
  </div>
</article>
